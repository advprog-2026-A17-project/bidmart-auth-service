# =========================
# Auth service local env
# Loaded only on local profile via application-local.properties
# =========================

# Runtime profile (optional)
SPRING_PROFILES_ACTIVE=local

# Server
PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bidmart_auth_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# Google OAuth (required for /api/v1/auth/oauth/login)
OAUTH_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Email verification app settings
AUTH_EMAIL_VERIFICATION_BASE_URL=http://localhost:3000/verify-email
AUTH_EMAIL_VERIFICATION_FROM=no-reply@bidmart.local
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
AUTH_EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# SMTP mail sender (required to actually send emails)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# RabbitMQ broker (required for wallet provisioning outbox publisher)
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# Wallet provisioning outbox event config
AUTH_WALLET_PROVISIONING_SOURCE=bidmart-auth-service
AUTH_WALLET_PROVISIONING_EXCHANGE=bidmart.wallet.provisioning
AUTH_WALLET_PROVISIONING_ROUTING_KEY=wallet.provision.requested.v1
AUTH_WALLET_PROVISIONING_OUTBOX_PUBLISH_DELAY_MS=5000
AUTH_WALLET_PROVISIONING_OUTBOX_BATCH_SIZE=50
AUTH_WALLET_PROVISIONING_OUTBOX_MAX_ATTEMPTS=10
AUTH_WALLET_PROVISIONING_OUTBOX_RETRY_BASE_SECONDS=30
AUTH_WALLET_PROVISIONING_OUTBOX_RETRY_MAX_SECONDS=900

# JWT authentication
# IMPORTANT: Change the secret in production! Must be >= 32 characters for HMAC-SHA256.
AUTH_JWT_SECRET=bidmart-auth-secret-key-bidmart-auth-secret-key
AUTH_JWT_ACCESS_TTL_SECONDS=900
AUTH_JWT_REFRESH_TTL_SECONDS=604800
