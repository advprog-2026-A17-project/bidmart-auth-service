# =========================
# Auth service local env
# Loaded only on local profile via application-local.properties
# =========================

# Runtime profile (optional)
spring.profiles.active=local

# Server
server.port=8080

# Database
spring.datasource.url=jdbc:postgresql://localhost:5432/bidmart_auth_db
spring.datasource.username=postgres
spring.datasource.password=password

# Google OAuth (required for /api/v1/auth/oauth/login)
oauth.google.client-id=your-google-web-client-id.apps.googleusercontent.com

# Email verification app settings
app.auth.email-verification.base-url=http://localhost:3000/verify-email
app.auth.email-verification.from=no-reply@bidmart.local
app.auth.email-verification.token-ttl-seconds=86400
app.auth.email-verification.resend-cooldown-seconds=60

# SMTP mail sender (required to actually send emails)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=your-email@gmail.com
spring.mail.password=your-app-password
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# RabbitMQ broker (required for wallet provisioning outbox publisher)
spring.rabbitmq.host=localhost
spring.rabbitmq.port=5672
spring.rabbitmq.username=guest
spring.rabbitmq.password=guest

# Wallet provisioning outbox event config
app.auth.wallet-provisioning.source=bidmart-auth-service
app.auth.wallet-provisioning.exchange=bidmart.wallet.provisioning
app.auth.wallet-provisioning.routing-key=wallet.provision.requested.v1
app.auth.wallet-provisioning.outbox.publish-delay-ms=5000
app.auth.wallet-provisioning.outbox.batch-size=50
app.auth.wallet-provisioning.outbox.max-attempts=10
app.auth.wallet-provisioning.outbox.retry-base-seconds=30
app.auth.wallet-provisioning.outbox.retry-max-seconds=900